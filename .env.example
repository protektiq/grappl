# GRAPPL core environment
ENVIRONMENT=development
LOG_LEVEL=info

# Supabase (local) — GRAPPL uses non-default CLI ports to avoid colliding with other projects.
# Run: bash scripts/setup-supabase.sh
# That starts local Supabase and writes real SUPABASE_* keys plus DATABASE_URL into .env.local (gitignored).
SUPABASE_URL=http://127.0.0.1:54331
SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54332/postgres
# Same Postgres instance as SUPABASE_DB_URL; Go services and tests expect DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54332/postgres

# External APIs
ROBOFLOW_API_KEY=REPLACE_ME
ROBOFLOW_MODEL_ID=REPLACE_ME
ROBOFLOW_MODEL_VERSION=REPLACE_ME
ANTHROPIC_API_KEY=REPLACE_ME
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Local pipeline paths
GRAPPL_INPUT_DIR=/data/input
GRAPPL_OUTPUT_DIR=/data/output
GRAPPL_CLIP_DIR=/data/output/clips

# Service ports
INGEST_PORT=8081
INFERENCE_PORT=8082
CLIP_PORT=8083
ANALYSIS_PORT=8084
GATEWAY_PORT=8080
UI_PORT=80
